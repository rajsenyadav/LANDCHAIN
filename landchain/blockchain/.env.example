# blockchain/.env.example
# Copy to .env and fill values

# From Alchemy.com → Create App → Ethereum → Sepolia
ALCHEMY_SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# MetaMask private key: 3 dots → Account Details → Export Private Key
# WARNING: Never share this. Never commit to GitHub.
PRIVATE_KEY=0x_your_metamask_private_key_here

# From Etherscan.io → Register → API Keys → Create (for contract verification)
ETHERSCAN_API_KEY=your_etherscan_api_key_here
